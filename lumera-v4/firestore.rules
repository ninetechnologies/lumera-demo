rules_version = '2';

// Regles Firestore Lumera Studio (refactor 2026-05-07 : sans firebase-admin)
// Bot webhook : email = webhook-bot@lumera-studio.fr / UID = iz8umKlReBeFt0skylYoSTHLK5t1
// Identifiants stockes en env vars Vercel : FIREBASE_BOT_EMAIL + FIREBASE_BOT_PASSWORD

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isWebhookBot() {
      return request.auth != null
             && request.auth.uid == 'iz8umKlReBeFt0skylYoSTHLK5t1';
    }

    // /admins
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // /reservations
    match /reservations/{id} {
      // Bot peut lire (pour /api/calendar.ics qui list toutes les resas).
      // Admin peut lire (dashboard).
      allow read: if isAdmin() || isWebhookBot();

      allow create: if isWebhookBot()
                    && id.matches('^cs_(test|live)_[A-Za-z0-9]+$')
                    && request.resource.data.stripeSessionId == id
                    && request.resource.data.paid == true
                    && request.resource.data.keys().hasAll([
                         'stripeSessionId', 'prenom', 'nom', 'email',
                         'telephone', 'service', 'duree', 'dateISO',
                         'startHour', 'dureeHours', 'creneau', 'slotIds',
                         'prix', 'acompte', 'paid', 'createdAt', 'projet'
                       ])
                    && request.resource.data.keys().hasOnly([
                         'stripeSessionId', 'prenom', 'nom', 'email',
                         'telephone', 'service', 'duree', 'dateISO',
                         'startHour', 'dureeHours', 'creneau', 'slotIds',
                         'prix', 'acompte', 'paid', 'createdAt', 'projet'
                       ])
                    && request.resource.data.prenom is string
                    && request.resource.data.prenom.size() > 0
                    && request.resource.data.prenom.size() <= 100
                    && request.resource.data.nom is string
                    && request.resource.data.nom.size() > 0
                    && request.resource.data.nom.size() <= 100
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.telephone is string
                    && request.resource.data.telephone.size() <= 30
                    && request.resource.data['service'] is string
                    && (request.resource.data['service'] == 'Plateau complet' || request.resource.data['service'] == 'Studio Podcast')
                    && request.resource.data.duree is string
                    && (request.resource.data.duree == '1' || request.resource.data.duree == '2' || request.resource.data.duree == '3' || request.resource.data.duree == '4' || request.resource.data.duree == '8' || request.resource.data.duree == 'soiree')
                    && request.resource.data.dateISO is string
                    && request.resource.data.dateISO.size() == 10
                    && request.resource.data.creneau is string
                    && request.resource.data.creneau.size() <= 50
                    && request.resource.data.projet is string
                    && request.resource.data.projet.size() <= 2000
                    && request.resource.data.startHour is int
                    && request.resource.data.startHour >= 0
                    && request.resource.data.startHour <= 23
                    && request.resource.data.dureeHours is int
                    && request.resource.data.dureeHours >= 1
                    && request.resource.data.dureeHours <= 12
                    && request.resource.data.prix is int
                    && request.resource.data.prix > 0
                    && request.resource.data.prix <= 10000
                    && request.resource.data.acompte is int
                    && request.resource.data.acompte > 0
                    && request.resource.data.acompte < request.resource.data.prix
                    && request.resource.data.slotIds is list
                    && request.resource.data.slotIds.size() > 0
                    && request.resource.data.slotIds.size() <= 12
                    && request.resource.data.createdAt is timestamp;

      allow update: if isAdmin()
                    && request.resource.data.stripeSessionId == resource.data.stripeSessionId
                    && request.resource.data.prix == resource.data.prix
                    && request.resource.data.acompte == resource.data.acompte
                    && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isAdmin();
    }

    // /slots
    // - read public : necessaire pour afficher dispo en temps reel cote client
    //   non authentifie (subscribeTakenSlots).
    // - create : tout visiteur peut lock un slot (TTL 30min via lockedUntil).
    // - update : bot + admin uniquement.
    // - delete : restreint au cas "lock expire" (lockedUntil < now) pour qu'un
    //   visiteur libere son propre lock OU bot/admin pour gestion. Sans cette
    //   restriction, n'importe qui pouvait DELETE un slot CONFIRMÉ (resa
    //   payee) -> double booking.
    match /slots/{slotId} {
      allow read: if true;
      allow create: if slotId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}$')
                    && request.resource.data.taken == true
                    && request.resource.data.keys().hasAll(['taken','lockedAt'])
                    && request.resource.data.keys().hasOnly(['taken','lockedAt','lockedUntil']);
      allow update: if isAdmin() || isWebhookBot();
      allow delete: if isAdmin() || isWebhookBot()
                    || (resource.data.lockedUntil != null
                        && resource.data.lockedUntil < request.time);
    }

    // /pending_reservations
    match /pending_reservations/{sessionId} {
      allow read: if isAdmin();
      allow create, update: if false;
      allow delete: if isWebhookBot() || isAdmin();
    }

    // /stripe_processed_sessions
    match /stripe_processed_sessions/{sessionId} {
      allow read: if isAdmin() || isWebhookBot();
      allow create: if isWebhookBot()
                    && sessionId.matches('^cs_(test|live)_[A-Za-z0-9]+$')
                    && request.resource.data.keys().hasOnly(['processedAt', 'eventType'])
                    && request.resource.data.processedAt is timestamp
                    && request.resource.data.eventType is string
                    && request.resource.data.eventType.size() <= 100;
      allow update, delete: if false;
    }

    // /stripe_events
    match /stripe_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isWebhookBot()
                    && eventId.matches('^evt_[A-Za-z0-9_]+$')
                    && request.resource.data.keys().hasOnly(['type', 'receivedAt', 'sessionId'])
                    && request.resource.data.receivedAt is timestamp
                    && request.resource.data.type is string
                    && request.resource.data.sessionId is string;
      allow update, delete: if false;
    }

    // /email_failures (FIX P1 #2 : trace les emails qui ratent au moment
    // de la confirmation d'une resa — admin peut voir lesquels ont rate
    // pour eventuellement renvoyer manuellement).
    match /email_failures/{sessionId} {
      allow read: if isAdmin();
      allow create: if isWebhookBot()
                    && sessionId.matches('^cs_(test|live)_[A-Za-z0-9]+$')
                    && request.resource.data.keys().hasOnly(['clientFailed', 'adminFailed', 'clientReason', 'adminReason', 'failedAt'])
                    && request.resource.data.clientFailed is bool
                    && request.resource.data.adminFailed is bool
                    && request.resource.data.clientReason is string
                    && request.resource.data.clientReason.size() <= 500
                    && request.resource.data.adminReason is string
                    && request.resource.data.adminReason.size() <= 500
                    && request.resource.data.failedAt is timestamp;
      allow update, delete: if false;
    }

    // refus par defaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
