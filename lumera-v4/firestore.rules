rules_version = '2';

// Regles Firestore Lumera Studio
// Philosophie :
// - /reservations : lecture/ecriture reservees aux admins. Creation via webhook
//   Stripe uniquement (firebase-admin SDK bypass les rules).
// - /slots : lecture publique (pour afficher la grille), creation/delete publics
//   pour le flow de lock, mais forme du document contrainte.
// - /pending_reservations : creation publique (le client pose son payload avant
//   redirection Stripe), lecture admin seulement.
// - /stripe_processed_sessions : ecrit par webhook uniquement (admin SDK).
// - /admins : lecture par l'admin lui-meme uniquement, ecriture interdite depuis
//   le client (gestion manuelle via console Firebase).

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidSlotId(id) {
      // Format attendu : YYYY-MM-DD_HH-mm (ex: 2026-05-12_14-00)
      return id.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}$');
    }

    function isValidSessionId(id) {
      // Stripe Checkout session id : cs_test_... ou cs_live_...
      return id.matches('^cs_(test|live)_[A-Za-z0-9]+$');
    }

    // ── /admins ─────────────────────────────────────────────────────────
    match /admins/{uid} {
      // L'admin peut lire son propre doc pour confirmer son role.
      allow read: if request.auth != null && request.auth.uid == uid;
      // Aucune ecriture depuis le client. Ajout d'un admin = manuel dans la
      // console Firebase.
      allow write: if false;
    }

    // ── /reservations ───────────────────────────────────────────────────
    match /reservations/{id} {
      // Lecture : admin uniquement (proteger les coordonnees clients).
      allow read: if isAdmin();
      // Mise a jour & suppression : admin uniquement (pour annuler).
      allow update, delete: if isAdmin();
      // Creation : INTERDITE depuis le client. Le webhook Stripe cree les
      // reservations via firebase-admin SDK qui bypass ces rules.
      allow create: if false;
    }

    // ── /slots ──────────────────────────────────────────────────────────
    match /slots/{slotId} {
      // Lecture publique : la grille affiche les slots deja pris.
      allow read: if true;

      // Creation : n'importe qui peut lock un slot, mais uniquement en posant
      // taken:true + lockedAt. lockedUntil optionnel (pour TTL cron).
      // L'id doit matcher le format slot.
      allow create: if isValidSlotId(slotId)
                    && request.resource.data.taken == true
                    && request.resource.data.keys().hasAll(['taken','lockedAt'])
                    && request.resource.data.keys().hasOnly(['taken','lockedAt','lockedUntil']);

      // Update : admin uniquement (pour forcer un deverrouillage).
      allow update: if isAdmin();

      // Delete : n'importe qui peut liberer un lock (rollback user, cancel
      // Stripe, cleanup cron, annulation admin).
      allow delete: if true;
    }

    // ── /pending_reservations ───────────────────────────────────────────
    // Ecrit UNIQUEMENT par create-checkout-session (admin SDK bypass rules).
    // Le client ne doit jamais y toucher directement.
    match /pending_reservations/{sessionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── /stripe_processed_sessions ──────────────────────────────────────
    // Ecrit uniquement par le webhook (firebase-admin SDK bypass rules).
    // Le client ne doit jamais y toucher.
    match /stripe_processed_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── /stripe_events (log audit) ──────────────────────────────────────
    match /stripe_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Refus par defaut pour toute autre collection ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
