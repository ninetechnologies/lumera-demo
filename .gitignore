# Données sensibles — NE JAMAIS commiter depuis ce repo
# Tout ce qui contient IBAN, SIRET client, KBIS, captures bancaires,
# fiche de renseignements client, contrats/factures/reçus signés,
# doit vivre dans /05-archives-admin/ (hors git) et jamais ici.

# Fichiers PDF administratifs
*.pdf

# Fichiers bureautiques (fiches de renseignements, contrats Word)
*.docx
*.doc
*.xlsx
*.xls

# Captures bancaires / preuves de paiement
*.jpeg
*.jpg
*.png
!lumera-v4/**/*.jpg
!lumera-v4/**/*.jpeg
!lumera-v4/**/*.png
!lumera-v4/**/*.svg
!LOGOLUMERASANSFOND.svg

# Dossiers sensibles
contrat/
preuves-paiement/
justificatifs/
documents-signes/

# WhatsApp exports (souvent contiennent des données perso)
WhatsApp*
whatsapp*

# Secrets / env
.env
.env.*
*.key
*.pem
service-account*.json
firebase-admin*.json

# Brief perso Loulou (généré côté client, pas du code projet)
lumera-modifs.html

# OS / IDE
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Node
node_modules/
dist/
.cache/
